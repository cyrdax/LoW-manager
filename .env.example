EVE_CLIENT_ID=
EVE_CLIENT_SECRET=
EVE_CALLBACK_URL=http://localhost:3100/auth/callback
PORT=3100
CONTACT_EMAIL=you@example.com
COOKIE_SECRET=change-me-to-a-long-random-string
APP_BASE_URL=http://localhost:5173

# Postgres is the target runtime DB for multi-tenant work. SQLite remains in use
# until the store cutover phases are complete.
DATABASE_URL=postgres://eve_app:eve_app_dev@127.0.0.1:55432/eve_fleet_dashboard
TEST_DATABASE_URL=postgres://eve_app:eve_app_dev@127.0.0.1:55432/eve_fleet_dashboard_test
DATABASE_SSL=false

# Generate with: openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=

# Dev email mode prints verification/reset URLs to server logs.
EMAIL_MODE=dev
RESEND_API_KEY=
EMAIL_FROM=

# Optional locally. When empty, Google login is disabled.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3100/auth/google/callback
